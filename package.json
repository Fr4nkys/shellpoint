{
  "name": "shellpoint",
  "version": "1.0.9",
  "description": "Professional SSH manager and SFTP client built specifically for Check Point firewall engineers",
  "main": "main.js",
  "homepage": "https://github.com/Fr4nkys/shellpoint",
  "repository": {
    "type": "git",
    "url": "https://github.com/Fr4nkys/shellpoint.git"
  },
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.shellpoint.app",
    "productName": "ShellPoint",
    "copyright": "© 2025 Alexandro Michel Davide — franksec.com",
    "icon": "src/assets/logo.png",
    "asar": true,
    "asarUnpack": [
      "**/*.node",
      "**/keytar/**",
      "**/ssh2/lib/protocol/crypto/**"
    ],
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "node_modules/**/*",
      "!node_modules/**/{test,tests,__tests__,spec,specs}/**",
      "!node_modules/**/*.md",
      "!node_modules/**/*.map",
      "!node_modules/**/README*",
      "!node_modules/**/CHANGELOG*",
      "!node_modules/**/LICENCE*",
      "!node_modules/**/LICENSE*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": ["x64"]
        },
        {
          "target": "zip",
          "arch": ["x64"]
        }
      ],
      "requestedExecutionLevel": "asInvoker",
      "verifyUpdateCodeSignature": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "ShellPoint",
      "license": "LICENSE"
    },
    "compression": "maximum"
  },
  "author": {
    "name": "Alexandro Michel Davide",
    "email": "",
    "url": "https://franksec.com"
  },
  "license": "MIT",
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "electron-store": "^7.0.3",
    "keytar": "^7.9.0",
    "ssh2": "^1.15.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  }
}
